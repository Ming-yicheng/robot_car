# Copy this file to .env, then adjust values on the Orange Pi.

# Local Qwen / RKLLM dialogue.
ROBOT_RKLLM_SERVER_URL=http://127.0.0.1:8080/rkllm_chat
ROBOT_QWEN_MODEL=qwen3-vl-2b-instruct-rkllm
ROBOT_RKLLM_TIMEOUT_SECONDS=120

# Local ASR/TTS.
ROBOT_LOCAL_ASR_ENABLED=true
ROBOT_LOCAL_ASR_LANGUAGE=auto
ROBOT_LOCAL_ASR_USE_ITN=true
ROBOT_LOCAL_TTS_ENABLED=true
ROBOT_LOCAL_TTS_SPEAKER_ID=0
ROBOT_LOCAL_TTS_SPEED=1.0
ROBOT_LOCAL_ONNX_PROVIDER=cpu
ROBOT_LOCAL_ONNX_THREADS=2

# Web dashboard. Leave empty to disable socket upload.
ROBOT_WEB_SERVER_URL=http://192.168.1.102:5000

# Optional runtime overrides.
ROBOT_CAMERA_BACKEND=opencv
ROBOT_CAMERA_DEVICE=0
ROBOT_FOLLOW_ENABLED_ON_START=false
ROBOT_SERVO_I2C_BUS=2
ROBOT_SERVO_I2C_ADDRESS=0x40
